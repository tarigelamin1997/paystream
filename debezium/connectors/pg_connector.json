{
  "name": "paystream-pg-connector",
  "config": {
    "connector.class": "io.debezium.connector.postgresql.PostgresConnector",
    "database.hostname": "${RDS_ENDPOINT}",
    "database.port": "5432",
    "database.user": "${RDS_USERNAME}",
    "database.password": "${RDS_PASSWORD}",
    "database.dbname": "paystream",
    "topic.prefix": "paystream",
    "plugin.name": "pgoutput",
    "publication.name": "paystream_publication",
    "table.include.list": "public.users,public.merchants,public.transactions,public.repayments,public.installment_schedules",
    "key.converter": "io.confluent.connect.avro.AvroConverter",
    "key.converter.schema.registry.url": "http://schema-registry.paystream.local:8081",
    "value.converter": "io.confluent.connect.avro.AvroConverter",
    "value.converter.schema.registry.url": "http://schema-registry.paystream.local:8081",
    "transforms": "unwrap,hashPii",
    "transforms.unwrap.type": "io.debezium.transforms.ExtractNewRecordState",
    "transforms.unwrap.add.fields": "op,source.ts_ms",
    "transforms.unwrap.delete.handling.mode": "rewrite",
    "transforms.unwrap.drop.tombstones": "true",
    "transforms.hashPii.type": "org.apache.kafka.connect.transforms.MaskField$Value",
    "transforms.hashPii.fields": "national_id",
    "transforms.hashPii.replacement": "********",
    "decimal.handling.mode": "string",
    "heartbeat.interval.ms": "10000",
    "errors.tolerance": "all",
    "errors.deadletterqueue.topic.name": "paystream.dlq",
    "errors.deadletterqueue.context.headers.enable": "true",
    "errors.deadletterqueue.topic.replication.factor": "1",
    "slot.name": "paystream_pg_slot",
    "publication.autocreate.mode": "disabled",
    "snapshot.mode": "initial"
  }
}
