{
  "title": "Bronze Ingestion Lag (> 60 min)",
  "ruleGroup": "paystream-alerts",
  "folderUID": "paystream",
  "condition": "C",
  "for": "5m",
  "labels": { "severity": "warning", "team": "paystream" },
  "annotations": {
    "summary": "Bronze ingestion lag exceeds 60 minutes",
    "description": "No new data ingested into bronze.pg_transactions_raw for over 60 minutes. Possible Kafka consumer or Debezium issue."
  },
  "data": [
    {
      "refId": "A",
      "datasourceUid": "PDEE91DDB90597936",
      "model": {
        "rawSql": "SELECT dateDiff('minute', max(_ingested_at), now()) AS lag_minutes FROM bronze.pg_transactions_raw",
        "format": "table"
      }
    },
    {
      "refId": "B",
      "datasourceUid": "__expr__",
      "model": {
        "type": "reduce",
        "expression": "A",
        "reducer": "last"
      }
    },
    {
      "refId": "C",
      "datasourceUid": "__expr__",
      "model": {
        "type": "threshold",
        "expression": "B",
        "conditions": [
          { "evaluator": { "type": "gt", "params": [60] } }
        ]
      }
    }
  ]
}
