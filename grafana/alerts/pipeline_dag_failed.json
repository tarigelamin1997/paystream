{
  "title": "Pipeline DAG Failed",
  "ruleGroup": "paystream-alerts",
  "folderUID": "paystream",
  "condition": "C",
  "for": "0s",
  "labels": { "severity": "critical", "team": "paystream" },
  "annotations": {
    "summary": "A pipeline DAG run has failed",
    "description": "gold.pipeline_audit_log contains a status='failed' row in the last hour."
  },
  "data": [
    {
      "refId": "A",
      "datasourceUid": "PDEE91DDB90597936",
      "model": {
        "rawSql": "SELECT count() AS fail_count FROM gold.pipeline_audit_log WHERE status = 'failed' AND event_time > now() - INTERVAL 1 HOUR",
        "format": "table"
      }
    },
    {
      "refId": "B",
      "datasourceUid": "__expr__",
      "model": {
        "type": "reduce",
        "expression": "A",
        "reducer": "last"
      }
    },
    {
      "refId": "C",
      "datasourceUid": "__expr__",
      "model": {
        "type": "threshold",
        "expression": "B",
        "conditions": [
          { "evaluator": { "type": "gt", "params": [0] } }
        ]
      }
    }
  ]
}
