{
  "uid": "paystream-merchant-ops",
  "title": "Merchant Operations",
  "tags": [
    "paystream",
    "merchant",
    "operations"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "GMV by Merchant (Last 24h)",
      "type": "barchart",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "PDEE91DDB90597936"
      },
      "targets": [
        {
          "rawSql": "SELECT merchant_id, merchant_category, gmv, transaction_count, approval_rate FROM gold.merchant_daily_kpis ORDER BY gmv DESC",
          "format": 1,
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PDEE91DDB90597936"
          },
          "editorType": "sql",
          "queryType": "sql"
        }
      ]
    },
    {
      "id": 2,
      "title": "Approval Rate (Last 24h)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "PDEE91DDB90597936"
      },
      "targets": [
        {
          "rawSql": "SELECT merchant_id, date, approval_rate FROM gold.merchant_daily_kpis ORDER BY merchant_id, date",
          "format": 1,
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PDEE91DDB90597936"
          },
          "editorType": "sql",
          "queryType": "sql"
        }
      ]
    },
    {
      "id": 3,
      "title": "BNPL Penetration Rate",
      "type": "gauge",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "PDEE91DDB90597936"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "value": 0,
                "color": "red"
              },
              {
                "value": 30,
                "color": "yellow"
              },
              {
                "value": 60,
                "color": "green"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "rawSql": "SELECT avg(bnpl_penetration) AS avg_bnpl FROM gold.merchant_daily_kpis",
          "format": 1,
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PDEE91DDB90597936"
          },
          "editorType": "sql",
          "queryType": "sql"
        }
      ]
    },
    {
      "id": 4,
      "title": "Decision Latency P95 (ms)",
      "type": "stat",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 6,
        "y": 8
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "PDEE91DDB90597936"
      },
      "targets": [
        {
          "rawSql": "SELECT now() AS time, quantile(0.50)(decision_latency_ms) AS p50, quantile(0.95)(decision_latency_ms) AS p95, quantile(0.99)(decision_latency_ms) AS p99 FROM silver.transactions_silver WHERE _ingested_at > now() - INTERVAL 24 HOUR",
          "format": 1,
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PDEE91DDB90597936"
          },
          "editorType": "sql",
          "queryType": "sql"
        }
      ]
    },
    {
      "id": 5,
      "title": "Top 10 Merchants by Transaction Count",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "PDEE91DDB90597936"
      },
      "targets": [
        {
          "rawSql": "SELECT merchant_id, sum(gmv) AS total_gmv FROM gold.merchant_daily_kpis GROUP BY merchant_id ORDER BY total_gmv DESC LIMIT 10",
          "format": 1,
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PDEE91DDB90597936"
          },
          "editorType": "sql",
          "queryType": "sql"
        }
      ]
    }
  ],
  "id": null
}