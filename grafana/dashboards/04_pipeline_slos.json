{
  "uid": "paystream-pipeline-slos",
  "title": "Pipeline SLOs",
  "tags": [
    "paystream",
    "slo",
    "pipeline"
  ],
  "timezone": "browser",
  "refresh": "1m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Ingestion Status (Bronze Freshness)",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "PDEE91DDB90597936"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 300,
                "color": "red"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "rawSql": "SELECT max(_ingested_at) AS last_ingested, dateDiff('minute', max(_ingested_at), now()) AS lag_minutes FROM bronze.pg_transactions_raw",
          "format": 1,
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PDEE91DDB90597936"
          },
          "editorType": "sql",
          "queryType": "sql"
        }
      ]
    },
    {
      "id": 2,
      "title": "dbt Run Status",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "PDEE91DDB90597936"
      },
      "targets": [
        {
          "rawSql": "SELECT test_name, status, execution_time, tested_at FROM gold.dbt_test_results ORDER BY tested_at DESC LIMIT 10",
          "format": 1,
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PDEE91DDB90597936"
          },
          "editorType": "sql",
          "queryType": "sql"
        }
      ]
    },
    {
      "id": 3,
      "title": "Gold Layer Freshness",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "PDEE91DDB90597936"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "dateTimeAsIso"
        }
      },
      "targets": [
        {
          "rawSql": "SELECT max(modification_time) AS last_gold_update FROM system.parts WHERE database = 'gold' AND active",
          "format": 1,
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PDEE91DDB90597936"
          },
          "editorType": "sql",
          "queryType": "sql"
        }
      ]
    },
    {
      "id": 4,
      "title": "Feature Pipeline Status",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "PDEE91DDB90597936"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "dateTimeAsIso"
        }
      },
      "targets": [
        {
          "rawSql": "SELECT max(_ingested_at) AS last_feature_update, dateDiff('hour', max(_ingested_at), now()) AS hours_since_update FROM feature_store.user_credit_features",
          "format": 1,
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PDEE91DDB90597936"
          },
          "editorType": "sql",
          "queryType": "sql"
        }
      ]
    },
    {
      "id": 5,
      "title": "Settlement Reconciliation Status",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 6
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "PDEE91DDB90597936"
      },
      "targets": [
        {
          "rawSql": "SELECT settlement_date, count() AS merchants, countIf(status = 'matched') AS matched, countIf(status = 'mismatch') AS mismatches, avg(variance_pct) AS avg_variance_pct FROM gold.settlement_reconciliation GROUP BY settlement_date ORDER BY settlement_date DESC LIMIT 5",
          "format": 1,
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PDEE91DDB90597936"
          },
          "editorType": "sql",
          "queryType": "sql"
        }
      ]
    },
    {
      "id": 6,
      "title": "SLO Summary",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "PDEE91DDB90597936"
      },
      "targets": [
        {
          "rawSql": "SELECT 'Feature Freshness' AS slo, '<6h' AS target, if(dateDiff('hour', max_ts, now()) < 6, 'PASS', 'FAIL') AS status FROM (SELECT max(_ingested_at) AS max_ts FROM feature_store.user_credit_features)",
          "format": 1,
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PDEE91DDB90597936"
          },
          "editorType": "sql",
          "queryType": "sql"
        }
      ]
    }
  ],
  "id": null
}