{
  "uid": "paystream-finops",
  "title": "FinOps & Resource Usage",
  "tags": [
    "paystream",
    "finops",
    "cost"
  ],
  "timezone": "browser",
  "refresh": "5m",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Storage by Layer (MB)",
      "type": "barchart",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "PDEE91DDB90597936"
      },
      "targets": [
        {
          "rawSql": "SELECT database, formatReadableSize(sum(bytes_on_disk)) AS disk_usage, sum(rows) AS total_rows FROM system.parts WHERE active GROUP BY database ORDER BY sum(bytes_on_disk) DESC",
          "format": 1,
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PDEE91DDB90597936"
          },
          "editorType": "sql",
          "queryType": "sql"
        }
      ]
    },
    {
      "id": 2,
      "title": "Query Cost Top 10 (by read bytes)",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "PDEE91DDB90597936"
      },
      "targets": [
        {
          "rawSql": "SELECT merchant_id, sum(gmv) AS total_gmv FROM gold.merchant_daily_kpis GROUP BY merchant_id ORDER BY total_gmv DESC LIMIT 10",
          "format": 1,
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PDEE91DDB90597936"
          },
          "editorType": "sql",
          "queryType": "sql"
        }
      ]
    },
    {
      "id": 3,
      "title": "Spark Job Hours (EMR Serverless)",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "PDEE91DDB90597936"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "h"
        }
      },
      "targets": [
        {
          "rawSql": "SELECT 0 AS executor_hours",
          "format": 1,
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PDEE91DDB90597936"
          },
          "editorType": "sql",
          "queryType": "sql"
        }
      ]
    },
    {
      "id": 4,
      "title": "API Invocations (24h)",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 8
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "PDEE91DDB90597936"
      },
      "targets": [
        {
          "expr": "sum(increase(http_requests_total{job=\"paystream-fastapi\"}[24h]))",
          "legendFormat": "Total Requests",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PDEE91DDB90597936"
          },
          "editorType": "sql",
          "queryType": "sql",
          "rawSql": "SELECT toStartOfHour(event_time) AS time, count() AS queries FROM system.query_log WHERE query LIKE '%feature_store%' AND type = 'QueryFinish' AND event_time >= now() - INTERVAL 24 HOUR GROUP BY time ORDER BY time",
          "format": 0
        }
      ]
    },
    {
      "id": 5,
      "title": "Table Engine Distribution",
      "type": "barchart",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 8
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "PDEE91DDB90597936"
      },
      "targets": [
        {
          "rawSql": "SELECT database, engine, count() AS table_count FROM system.tables WHERE database IN ('bronze','silver','gold','feature_store') GROUP BY database, engine ORDER BY database, engine",
          "format": 1,
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PDEE91DDB90597936"
          },
          "editorType": "sql",
          "queryType": "sql"
        }
      ]
    }
  ],
  "id": null
}