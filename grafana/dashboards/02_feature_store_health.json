{
  "uid": "paystream-feature-health",
  "title": "Feature Store Health",
  "tags": [
    "paystream",
    "feature-store",
    "health"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Feature Freshness (Last Update)",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "PDEE91DDB90597936"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "dateTimeAsIso"
        }
      },
      "targets": [
        {
          "rawSql": "SELECT max(_ingested_at) AS last_update FROM feature_store.user_credit_features",
          "format": 1,
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PDEE91DDB90597936"
          },
          "editorType": "sql",
          "queryType": "sql"
        }
      ]
    },
    {
      "id": 2,
      "title": "Feature API P99 Latency",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "PDEE91DDB90597936"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"paystream-fastapi\"}[5m])) by (le))",
          "legendFormat": "P99 Latency",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PDEE91DDB90597936"
          },
          "editorType": "sql",
          "queryType": "sql",
          "rawSql": "SELECT toStartOfMinute(event_time) AS time, quantile(0.99)(query_duration_ms) AS p99_ms FROM system.query_log WHERE query LIKE '%feature_store%' AND type = 'QueryFinish' AND event_time >= now() - INTERVAL 24 HOUR GROUP BY time ORDER BY time",
          "format": 0
        }
      ]
    },
    {
      "id": 3,
      "title": "Feature API Request Rate",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "PDEE91DDB90597936"
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"paystream-fastapi\"}[5m]))",
          "legendFormat": "Requests/sec",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PDEE91DDB90597936"
          },
          "editorType": "sql",
          "queryType": "sql",
          "rawSql": "SELECT toStartOfMinute(event_time) AS time, count() AS requests FROM system.query_log WHERE query LIKE '%feature_store%' AND type = 'QueryFinish' AND event_time >= now() - INTERVAL 24 HOUR GROUP BY time ORDER BY time",
          "format": 0
        }
      ]
    },
    {
      "id": 4,
      "title": "Feature Store Row Count",
      "type": "stat",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 6,
        "y": 6
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "PDEE91DDB90597936"
      },
      "targets": [
        {
          "rawSql": "SELECT count() AS total_rows FROM feature_store.user_credit_features",
          "format": 1,
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PDEE91DDB90597936"
          },
          "editorType": "sql",
          "queryType": "sql"
        }
      ]
    },
    {
      "id": 5,
      "title": "Feature Version Distribution",
      "type": "barchart",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "PDEE91DDB90597936"
      },
      "targets": [
        {
          "rawSql": "SELECT feature_version, count() AS cnt FROM feature_store.user_credit_features GROUP BY feature_version ORDER BY cnt DESC",
          "format": 1,
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PDEE91DDB90597936"
          },
          "editorType": "sql",
          "queryType": "sql"
        }
      ]
    }
  ],
  "id": null
}